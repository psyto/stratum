{
  "name": "stratum",
  "private": true,
  "scripts": {
    "prepare": "pnpm run build",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:core": "cd packages/core && yarn test",
    "test:evm:sdk": "cd packages/evm && yarn test",
    "test:solana": "cd contracts/solana && anchor test",
    "test:evm": "cd contracts/evm && forge test -vvv",
    "test:evm:fuzz": "cd contracts/evm && forge test --fuzz-runs 10000",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "prettier": "^2.6.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.31.0"
}
