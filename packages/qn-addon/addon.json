{
  "name": "Fabrknt Data Optimization",
  "slug": "fabrknt-data-optimization",
  "description": "Chain-agnostic data optimization for blockchain applications. Merkle tree operations for verifiable proofs and compact bitfield management for state tracking.",
  "version": "0.1.0",
  "author": "Fabrknt",
  "category": "developer-tools",
  "support": {
    "email": "support@fabrknt.com",
    "url": "https://fabrknt.com/support"
  },
  "repository": "https://github.com/psyto/stratum",
  "chains": [
    {
      "id": "solana",
      "name": "Solana"
    },
    {
      "id": "ethereum",
      "name": "Ethereum"
    }
  ],
  "healthcheck": "/healthcheck",
  "authentication": "basic",
  "provisioning": {
    "provision": "POST /provision",
    "update": "PUT /provision",
    "deactivate": "DELETE /provision/deactivate",
    "deprovision": "DELETE /provision"
  },
  "plans": [
    {
      "id": "starter",
      "name": "Starter",
      "price": 0,
      "description": "Full access to all Merkle tree and bitfield endpoints.",
      "rate_limit": {
        "requests_per_minute": 100
      },
      "features": [
        "Merkle tree build, proof, verify, and hash",
        "Bitfield create, set, check, and stats"
      ]
    },
    {
      "id": "pro",
      "name": "Pro",
      "price": 49,
      "description": "All Starter features plus higher rate limits and priority support.",
      "rate_limit": {
        "requests_per_minute": 500
      },
      "features": [
        "All Starter features",
        "Higher rate limits",
        "Priority support"
      ]
    }
  ],
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/merkle/build",
      "description": "Build a Merkle tree and return root hash",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/merkle/proof",
      "description": "Get Merkle proof for a leaf at given index",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/merkle/verify",
      "description": "Verify a Merkle proof against a root",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/merkle/hash",
      "description": "Hash a single leaf value",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/bitfield/create",
      "description": "Create a new empty bitfield of given size",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/bitfield/set",
      "description": "Set a bit at given index",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/bitfield/check",
      "description": "Check if a bit is set at given index",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/bitfield/stats",
      "description": "Get bitfield statistics (set count, capacity, fill rate)",
      "plan": "starter"
    }
  ]
}
